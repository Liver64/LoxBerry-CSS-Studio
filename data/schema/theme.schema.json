{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoxBerry CSS Framework Theme",
  "description": "Editable token source for generated LoxBerry user themes.",
  "type": "object",
  "required": [
    "name",
    "slug",
    "theme_id",
    "tokens"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,58}[a-z0-9]$"
    },
    "theme_id": {
      "type": "string",
      "pattern": "^user-[a-z0-9][a-z0-9-]{0,58}[a-z0-9]$"
    },
    "generated_by": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "tokens": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^--lb-[a-z0-9-]+$"
      }
    }
  }
}
